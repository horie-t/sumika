{
  "name": "sumika-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "gen:api": "npx --yes openapi-typescript@7 openapi.json -o src/api/schema.d.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "e2e": "bddgen && playwright test",
    "e2e:ui": "bddgen && playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "pg": "^8.22.0",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.8.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
